# Secret key of the issuing account (creates and controls the asset)
ISSUER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Secret key of the distribution account (holds and distributes the asset)
DISTRIBUTOR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Asset code (up to 12 characters)
ASSET_CODE=MYTOKEN

# Amount to issue to the distribution account
ISSUE_AMOUNT=1000000

# Use testnet or mainnet
NETWORK=testnet
